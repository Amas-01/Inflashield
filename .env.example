# InflaShield — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.
#
# See docs/SETUP.md for step-by-step instructions on getting each key.

# =============================================================================
# REQUIRED — the app will refuse to start without these
# =============================================================================

# SoSoValue API key
# Register: https://sosovalue.com → Developer → API Access
# Docs: https://sosovalue-1.gitbook.io/sosovalue-api-doc
# Buildathon higher limits: https://forms.gle/2nuJT2qNbUQsyyZy8
SOSOVALUE_API_KEY=

# SoDEX API key
# Register: https://sodex.com
# Testnet: generate key from developer dashboard — no extra application needed
# Mainnet: requires Silver rank OR Buildathon whitelist
# Docs: https://sodex.com/documentation/api/api
SODEX_API_KEY=

# ExchangeRate-API key
# Register (free, no credit card): https://www.exchangerate-api.com
# Free tier: 1,500 requests/month
# Docs: https://www.exchangerate-api.com/docs/overview
EXCHANGERATE_API_KEY=

# =============================================================================
# OPTIONAL — AI-enhanced signal explanations
# Leave both unset to use template-based explanations instead.
# See docs/AI.md for full provider comparison.
# =============================================================================

# AI provider: groq | gemini | anthropic | ollama
AI_PROVIDER=

# API key for the chosen provider
# Groq (free, recommended): https://console.groq.com
# Google Gemini (free): https://aistudio.google.com
# Anthropic (paid): https://console.anthropic.com
# Ollama (local, free): leave blank — uses OLLAMA_BASE_URL instead
AI_API_KEY=

# Ollama only — local server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# =============================================================================
# ENVIRONMENT — controls which SoDEX network is used
# =============================================================================

# testnet (default) | mainnet
# Use testnet until mainnet API access is granted
SODEX_ENV=testnet

# =============================================================================
# OPTIONAL — App configuration
# =============================================================================

# Default currency shown in the UI (ISO 4217 code)
# Users can always change this — this is just the initial value
DEFAULT_CURRENCY=USD

# Number of indices to fetch and score (default: 10)
# Lower this if you hit SoSoValue rate limits during development
INDEX_FETCH_LIMIT=10
